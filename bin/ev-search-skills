#!/usr/bin/env bash
#
# ev-search-skills — installer/scaffolder for the EV Search Skills suite.
#
# Works two ways:
#   • Installed via Homebrew — the formula sets EV_SKILLS_HOME to its libexec.
#   • Run from a git clone   — resolves EV_SKILLS_HOME from this script's location.
#
set -euo pipefail

VERSION="0.1.0"

# --- Resolve where the packaged skills + templates live -----------------------
if [[ -z "${EV_SKILLS_HOME:-}" ]]; then
  # script lives at <home>/bin/ev-search-skills → home is one dir up
  _self="${BASH_SOURCE[0]}"
  while [[ -h "$_self" ]]; do _self="$(readlink "$_self")"; done
  EV_SKILLS_HOME="$(cd "$(dirname "$_self")/.." && pwd)"
fi

SKILLS_SRC="$EV_SKILLS_HOME/.claude/skills"
CLAUDE_SKILLS_DIR="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"

# Skills owned by this package (so uninstall only removes ours)
EV_SKILLS=(ev-new-project ev-switch-project ev-search ev-detail ev-research ev-compare)

info()  { printf '  %s\n' "$*"; }
ok()    { printf '  \033[32m✓\033[0m %s\n' "$*"; }
warn()  { printf '  \033[33m!\033[0m %s\n' "$*" >&2; }
die()   { printf '\033[31merror:\033[0m %s\n' "$*" >&2; exit 1; }

cmd_install() {
  [[ -d "$SKILLS_SRC" ]] || die "packaged skills not found at $SKILLS_SRC"
  mkdir -p "$CLAUDE_SKILLS_DIR"
  printf 'Installing skills to %s\n' "$CLAUDE_SKILLS_DIR"
  for s in "${EV_SKILLS[@]}"; do
    if [[ -d "$SKILLS_SRC/$s" ]]; then
      rm -rf "${CLAUDE_SKILLS_DIR:?}/$s"
      cp -R "$SKILLS_SRC/$s" "$CLAUDE_SKILLS_DIR/$s"
      ok "$s"
    fi
  done
  printf '\nDone. The /ev-* commands are now available in Claude Code.\n'
  printf 'Next: create a workspace with  ev-search-skills scaffold my-ev-search\n'
}

cmd_uninstall() {
  printf 'Removing skills from %s\n' "$CLAUDE_SKILLS_DIR"
  for s in "${EV_SKILLS[@]}"; do
    if [[ -d "$CLAUDE_SKILLS_DIR/$s" ]]; then
      rm -rf "${CLAUDE_SKILLS_DIR:?}/$s"
      ok "removed $s"
    fi
  done
}

# Copy a template into the target dir only if it is not already present.
_seed() {
  local src="$1" dest="$2"
  if [[ -e "$dest" ]]; then
    warn "kept existing $(basename "$dest")"
  elif [[ -e "$src" ]]; then
    cp "$src" "$dest"; ok "created $(basename "$dest")"
  fi
}

cmd_scaffold() {
  local dir="${1:-.}"
  mkdir -p "$dir/projects"
  [[ -e "$dir/projects/.gitkeep" ]] || : > "$dir/projects/.gitkeep"
  _seed "$EV_SKILLS_HOME/state.md"           "$dir/state.md"
  _seed "$EV_SKILLS_HOME/search_criteria.md" "$dir/search_criteria.md"
  _seed "$EV_SKILLS_HOME/car-template.md"    "$dir/car-template.md"
  printf '\nWorkspace ready in %s\n' "$dir"
  printf 'Start Claude Code there and run:  /ev-new-project my-2026-search\n'
}

cmd_help() {
  cat <<EOF
ev-search-skills $VERSION — EV research skills for Claude Code

Usage:
  ev-search-skills install            Install the /ev-* skills into ~/.claude/skills
  ev-search-skills scaffold [dir]     Seed a research workspace (state.md, criteria, projects/)
  ev-search-skills uninstall          Remove the /ev-* skills from ~/.claude/skills
  ev-search-skills version            Print version
  ev-search-skills help               Show this help

Env overrides:
  CLAUDE_SKILLS_DIR   Target skills dir (default: ~/.claude/skills)
  EV_SKILLS_HOME      Source of packaged skills/templates (set by Homebrew)
EOF
}

main() {
  local sub="${1:-help}"; shift || true
  case "$sub" in
    install)   cmd_install "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    scaffold)  cmd_scaffold "$@" ;;
    version|--version|-v) printf '%s\n' "$VERSION" ;;
    help|--help|-h) cmd_help ;;
    *) die "unknown command '$sub' (try: ev-search-skills help)" ;;
  esac
}

main "$@"
