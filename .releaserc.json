{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "jq --arg v \"${nextRelease.version}\" '.version = $v' plugins/pingvinen-ev-search/.claude-plugin/plugin.json > plugin.json.tmp && mv plugin.json.tmp plugins/pingvinen-ev-search/.claude-plugin/plugin.json"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["plugins/pingvinen-ev-search/.claude-plugin/plugin.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
